{
  "name": "forgex",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently \"node backend/server.js\" \"npm --prefix frontend run dev -- --host 0.0.0.0\"",
    "dev:backend": "node backend/server.js",
    "dev:frontend": "npm --prefix frontend run dev -- --host 0.0.0.0",
    "build": "npm --prefix frontend run build",
    "preview": "npm --prefix frontend run preview -- --host 0.0.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
